#create a function that generate file name
list_climate_files <- function(folder_name) {
dir <- paste0("~/Dados/", folder_name, "/compiled")
list.files(dir, pattern = "\\.dbc$|\\.zip$", full.names = TRUE)
}
list_climate_files("Temperature")
#create a function that generate file name
list_climate_files <- function(folder_name) {
dir <- paste0("~/Dados/", folder_name, "/compiled")
list.files(dir, pattern = "\\.csv$", full.names = TRUE)
}
list_climate_files("Temperature")
